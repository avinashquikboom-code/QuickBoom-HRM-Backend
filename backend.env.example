# VPS runtime env for the backend container.
# Copy to /opt/quickboom/backend.env ON THE VPS and fill in real values.
# This file is read by docker-compose (env_file). It NEVER goes through GitHub.

NODE_ENV=production
HOST=0.0.0.0
PORT=5004

# Postgres runs on the VPS HOST — use host.docker.internal (not localhost):
DATABASE_URL=postgresql://quickboom_user:CHANGE_ME@host.docker.internal:5432/quickboom

# Generate: openssl rand -base64 32
JWT_SECRET=CHANGE_ME

# Optional integrations
GOOGLE_MAPS_API_KEY=
# Paste the full Firebase service-account JSON on one line (or leave empty):
FIREBASE_SERVICE_ACCOUNT_JSON=
SUPABASE_URL=
SUPABASE_ANON_KEY=
