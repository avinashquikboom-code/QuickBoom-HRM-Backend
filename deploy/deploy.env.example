# =============================================================================
# Deploy toolkit config — copy to /opt/quickboom/deploy.env on the VPS.
# Sourced by config.sh and all deploy-*.sh scripts. Tune values here only.
# =============================================================================

# --- AWS / ECR ---
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=546941058055
ECR_REGISTRY=546941058055.dkr.ecr.ap-south-1.amazonaws.com

# Repository names as they exist in ECR
BACKEND_REPO=hrm-backend
ADMIN_REPO=hrm-admin

# Image tag to deploy (latest, or a specific git sha for rollbacks)
IMAGE_TAG=latest

# --- Container names ---
BACKEND_CONTAINER=hrm-backend
ADMIN_CONTAINER=hrm-admin

# --- Host ports (mapped to container ports) ---
BACKEND_PORT=5004      # container listens on 5004
ADMIN_PORT=3000        # container listens on 3000

# --- Env files (runtime secrets, created separately on the VPS) ---
BACKEND_ENV_FILE=/opt/quickboom/backend.env
ADMIN_ENV_FILE=/opt/quickboom/frontend.env

# =============================================================================
# Resource limits — host has 2 vCPU / ~1.9GB RAM. Keep headroom for Postgres+OS.
# CPU is in cores (1.0 = one full core). Memory accepts docker units (m/g).
# =============================================================================

# Backend (Node/Express + Prisma)
BACKEND_CPUS=1.0
BACKEND_MEMORY=640m
BACKEND_MEMORY_RESERVATION=320m

# Admin panel (Next.js standalone — light at runtime)
ADMIN_CPUS=0.75
ADMIN_MEMORY=512m
ADMIN_MEMORY_RESERVATION=256m
