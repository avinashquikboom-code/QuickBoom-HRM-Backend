# Config for db-backup.sh — copy to /opt/quickboom/backup/.env on the VPS (chmod 600).
# AWS auth: prefer an EC2 instance role (no keys needed). Otherwise set the two
# AWS_* keys below, or run `aws configure` for the cron user.

# Project name => S3 folder/prefix. Each project's backups go under this.
PROJECT_NAME=hrm

# --- Database (host Postgres) ---
PGHOST=localhost
PGPORT=5432
PGDATABASE=quickboom
PGUSER=quickboom_user
PGPASSWORD=CHANGE_ME

# --- S3 destination (YOU configure AWS) ---
S3_BUCKET=your-backup-bucket-name
AWS_REGION=ap-south-1
S3_STORAGE_CLASS=STANDARD_IA

# Optional explicit AWS creds (leave empty to use EC2 instance role / aws configure)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Retention ---
LOCAL_BACKUP_DIR=/opt/quickboom/backup/dumps
LOCAL_RETENTION_DAYS=2      # delete local dumps older than N days
S3_RETENTION_DAYS=30        # delete S3 objects older than N days (0 = keep forever)
