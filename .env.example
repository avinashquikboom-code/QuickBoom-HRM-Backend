# Quickboom Backend Environment Variables
# Copy this file to .env for local development
# On Render, set these in the dashboard under Environment Variables

# === REQUIRED ===
# PostgreSQL database connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# For local dev: postgresql://postgres:password@localhost:5432/quickboom
# For Render: use Render PostgreSQL Internal URL or external Supabase URL
DATABASE_URL=postgresql://postgres:password@localhost:5432/quickboom

# JWT secret for signing auth tokens (MUST be strong in production)
# Generate: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# === OPTIONAL / CLOUD ===
# Server host (defaults to 0.0.0.0 for cloud deployment)
HOST=0.0.0.0

# Server port (Render auto-sets this to 10000, 5003 for local dev)
PORT=5003

# Google Maps API key (for geocoding/location features)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Firebase service account JSON for push notifications
# Paste the entire JSON content of your Firebase service account key here
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Alternative: path to Firebase credentials file (local dev only)
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
