# Quickboom Backend Environment Variables
# Copy this file to .env for local development
# On Render, set these in the dashboard under Environment Variables

# === REQUIRED ===
# PostgreSQL database connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/quickboom

# JWT secret for signing auth tokens (generate a strong random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# === OPTIONAL ===
# Server host (defaults to 0.0.0.0 for cloud deployment)
HOST=0.0.0.0

# Server port (Render sets this automatically)
PORT=3000

# Firebase service account JSON for push notifications
# Paste the entire JSON content of your Firebase service account key here
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Alternative: path to Firebase credentials file (local dev only)
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
