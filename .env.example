# Quickboom Backend Environment Variables
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual values below
# 3. NEVER commit .env to git (it is already in .gitignore)
# 4. On Render, set these individually in the Environment tab

# === REQUIRED ===

# PostgreSQL database connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Local dev:
DATABASE_URL=postgresql://quickboom_user:Quickboom@2026@localhost:5432/quickboom
# Production (Supabase):
# DATABASE_URL=postgresql://postgres.hxxohzqrzcyjzsbnopky:dbInd5rGfMl5QElC@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# JWT secret for signing auth tokens
# ⚠️ Change this to a strong random string for production
# Generate: openssl rand -base64 32
JWT_SECRET=quickboom-dev-jwt-secret-change-me

# === OPTIONAL / CLOUD ===

# Server host (0.0.0.0 for cloud, 127.0.0.1 for local only)
HOST=0.0.0.0

# Server port (5003 for local dev, 10000 for Render)
PORT=3000

# Google Maps API key (for geocoding/location features)
GOOGLE_MAPS_API_KEY=AIzaSyBlyaQhZkTtPScZ6ZTCZVMQX-bSY-B0VYI

# Firebase service account JSON for push notifications (optional)
# Paste the entire JSON content of your Firebase service account key here
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Alternative: path to Firebase credentials file (local dev only)
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# Supabase Configurations
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Firebase Configurations
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-client-email@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_ID=your-client-id
