generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             Int             @id @default(autoincrement())
  email          String          @unique
  password       String
  role           Role            @default(EMPLOYEE)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  fcmTokens      String[]        @default([])
  comments       Comment[]
  employee       Employee?
  profile        Profile?
  assignedTasks  Task[]          @relation("AssignedByTasks")
  userPermission UserPermission?
  notifications  Notification[]
}

model Profile {
  id                Int      @id @default(autoincrement())
  userId            Int      @unique
  email             String
  fullName          String
  phone             String   @default("")
  avatarUrl         String?  @default("/favicon.svg")
  timezone          String   @default("Asia/Kolkata")
  timezoneLabel     String   @default("(GMT+5:30) Mumbai, New Delhi")
  bio               String   @default("")
  twoFactorEnabled  Boolean  @default(false)
  twoFactorStatus   String   @default("disabled")
  lastLoginAt       DateTime @default(now())
  lastLoginLocation String   @default("Unknown")
  clearanceLevel    Int      @default(1)
  clearanceLabel    String   @default("Level 1 (General)")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Office {
  id                   Int          @id @default(autoincrement())
  name                 String
  code                 String?      @unique
  address              String
  latitude             Float
  longitude            Float
  idealRadiusMeters    Float        @default(25.0)
  maxPunchRadiusMeters Float        @default(50.0)
  isActive             Boolean      @default(true)
  subscriptionPlan     String       @default("Basic")
  billingCycle         String       @default("monthly")
  invoiceStatus        String       @default("Paid")
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  attendances          Attendance[]
  employees            Employee[]
}

model Department {
  id        Int        @id @default(autoincrement())
  name      String
  code      String?    @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  employees Employee[]
}

model Employee {
  id               Int               @id @default(autoincrement())
  userId           Int?              @unique
  employeeCode     String            @unique
  firstName        String
  lastName         String
  designation      String?
  status           String            @default("active")
  officeId         Int?
  departmentId     Int?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  attendances      Attendance[]
  department       Department?       @relation(fields: [departmentId], references: [id])
  office           Office?           @relation(fields: [officeId], references: [id])
  user             User?             @relation(fields: [userId], references: [id])
  expenses         Expense[]
  leaveRequests    LeaveRequest[]
  leaveBalance     LeaveBalance?
  notifications    Notification[]
  shiftAssignments ShiftAssignment[]
  assignedTasks    Task[]            @relation("AssignedTasks")
  payslips         Payslip[]
  documents        Document[]
  attendanceCorrections AttendanceCorrection[]
}

model Attendance {
  id                    Int       @id @default(autoincrement())
  employeeId            Int
  officeId              Int?
  date                  String
  checkIn               DateTime?
  checkOut              DateTime?
  status                String    @default("ABSENT")
  notes                 String?
  latitude              Float?
  longitude             Float?
  isFingerprintCheckIn  Boolean   @default(false)
  isFingerprintCheckOut Boolean   @default(false)
  isOnBreak             Boolean   @default(false)
  breakStartTime        DateTime?
  totalBreakSeconds     Int       @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  employee              Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  office                Office?   @relation(fields: [officeId], references: [id])
  attendanceCorrections AttendanceCorrection[]
}

model Comment {
  id         Int      @id @default(autoincrement())
  entityType String
  entityId   String
  content    String
  authorId   Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model LiveLocation {
  id         Int      @id @default(autoincrement())
  employeeId Int      @unique
  name       String
  role       String
  lat        Float
  lng        Float
  status     String
  speed      String   @default("0 km/h")
  battery    String   @default("100%")
  updatedAt  DateTime @updatedAt
}

model LeaveRequest {
  id         Int      @id @default(autoincrement())
  employeeId Int
  type       String
  fromDate   DateTime
  toDate     DateTime
  reason     String
  status     String   @default("PENDING")
  appliedOn  DateTime @default(now())
  reviewedBy String?
  reviewNote String?
  reviewedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model LeaveBalance {
  id           Int      @id @default(autoincrement())
  employeeId   Int      @unique
  fiscalYear   String   @default("2026")
  casualTotal  Int      @default(12)
  casualUsed   Int      @default(0)
  sickTotal    Int      @default(10)
  sickUsed     Int      @default(0)
  earnedTotal  Int      @default(15)
  earnedUsed   Int      @default(0)
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Expense {
  id          Int      @id @default(autoincrement())
  employeeId  Int
  category    String
  amount      Float
  description String
  date        DateTime
  status      String   @default("PENDING")
  submittedOn DateTime @default(now())
  reviewedBy  String?
  reviewNote  String?
  hasReceipt  Boolean  @default(false)
  receiptUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Task {
  id           Int      @id @default(autoincrement())
  title        String
  description  String
  assignedToId Int
  assignedById Int
  projectName  String
  dueDate      DateTime
  status       String   @default("TODO")
  priority     String   @default("MEDIUM")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  assignedBy   User     @relation("AssignedByTasks", fields: [assignedById], references: [id], onDelete: Cascade)
  assignedTo   Employee @relation("AssignedTasks", fields: [assignedToId], references: [id], onDelete: Cascade)
}

model Shift {
  id           Int               @id @default(autoincrement())
  name         String
  startTime    String
  endTime      String
  workingDays  String[]
  graceMinutes Int               @default(15)
  breakMinutes Int               @default(60)
  color        String            @default("#3BA38B")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  assignments  ShiftAssignment[]
}

model ShiftAssignment {
  id            Int       @id @default(autoincrement())
  employeeId    Int
  shiftId       Int
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift         Shift     @relation(fields: [shiftId], references: [id], onDelete: Cascade)
}

model Notification {
  id         Int       @id @default(autoincrement())
  employeeId Int?
  userId     Int?
  title      String
  body       String
  category   String    @default("GENERAL")
  isRead     Boolean   @default(false)
  actionId   String?
  actionType String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Holiday {
  id          Int      @id @default(autoincrement())
  name        String
  date        DateTime
  isPublic    Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Document {
  id          Int      @id @default(autoincrement())
  title       String
  type        String
  date        DateTime
  fileSize    String
  filePath    String?
  employeeId  Int?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  employee    Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model AttendanceCorrection {
  id                Int       @id @default(autoincrement())
  attendanceId      Int
  employeeId        Int
  correctionType    String
  requestedCheckIn  DateTime?
  requestedCheckOut DateTime?
  originalCheckIn   DateTime?
  originalCheckOut  DateTime?
  reason            String
  status            String    @default("PENDING")
  requestedBy       String
  reviewedBy        String?
  reviewedAt        DateTime?
  approvedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  attendance        Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  employee          Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Announcement {
  id          Int      @id @default(autoincrement())
  title       String
  content     String
  category    String   @default("GENERAL")
  publishedBy String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PricingPlan {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  monthlyPrice Float
  yearlyPrice  Float
  seatsLabel   String   @default("")
  description  String   @default("")
  features     String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model RolePermission {
  id          Int      @id @default(autoincrement())
  role        Role     @unique
  permissions Json
  updatedAt   DateTime @updatedAt
}

model UserPermission {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  permissions Json
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemSetting {
  id            Int      @id @default(1)
  platformName  String   @default("Super HRM")
  supportEmail  String   @default("admin@hrm.com")
  currency      String   @default("INR")
  locale        String   @default("en")
  twoFactor     Boolean  @default(true)
  sessionLock   Boolean  @default(true)
  auditLogs     Boolean  @default(true)
  ipRestriction Boolean  @default(false)
  notifications Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum Role {
  SUPER_ADMIN
  ADMIN
  HR
  PLATFORM_ADMIN
  EMPLOYEE
}

model Payslip {
  id                Int      @id @default(autoincrement())
  employeeId        Int
  month             Int
  year              Int
  baseSalary        Float
  allowance         Float
  deductions        Float
  netSalary         Float
  status            String   @default("Approved")
  employeeCode      String
  employeeName      String
  designation       String
  department        String
  officeName        String
  netInWords        String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  employee          Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month, year])
}
