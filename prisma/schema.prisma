generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String             @id @default(uuid()) @db.Uuid
  email          String          @unique
  password       String
  role           Role            @default(EMPLOYEE)
  isActive       Boolean         @default(true)
  employeeID     String?         @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  comments       Comment[]
  employee       Employee?
  profile        Profile?
  assignedTasks  Task[]          @relation("AssignedByTasks")
  userPermission UserPermission?
  notifications  Notification[]
  fcmTokens      FCMToken[]
  sessions       UserSession[]
  devices        Device[]
}

model Profile {
  id                String      @id @default(uuid()) @db.Uuid
  userId            String @db.Uuid      @unique
  email             String
  fullName          String
  phone             String   @default("")
  avatarUrl         String?  @default("/favicon.svg")
  timezone          String   @default("Asia/Kolkata")
  timezoneLabel     String   @default("(GMT+5:30) Mumbai, New Delhi")
  bio               String   @default("")
  twoFactorEnabled  Boolean  @default(false)
  twoFactorStatus   String   @default("disabled")
  lastLoginAt       DateTime @default(now())
  lastLoginLocation String   @default("Unknown")
  clearanceLevel    Int      @default(1)
  clearanceLabel    String   @default("Level 1 (General)")
  aadharNumber      String?  @default("")
  panNumber         String?  @default("")
  voterId           String?  @default("")
  passportNumber    String?  @default("")
  pfNumber          String?  @default("")
  esicNumber        String?  @default("")
  isHandicapped     Boolean  @default(false)
  currentAddress    String?  @default("")
  permanentAddress  String?  @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Office {
  id                   String          @id @default(uuid()) @db.Uuid
  name                 String
  code                 String?      @unique
  address              String
  latitude             Float        @db.DoublePrecision
  longitude            Float        @db.DoublePrecision
  idealRadiusMeters    Float        @default(25.0)
  maxPunchRadiusMeters Float        @default(50.0)
  isActive             Boolean      @default(true)
  subscriptionPlan     String       @default("Basic")
  billingCycle         String       @default("monthly")
  invoiceStatus        String       @default("Paid")
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  workingHoursStart    String       @default("09:00")
  workingHoursEnd      String       @default("18:00")
  workingDays          String[]     @default(["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"])
  attendances          Attendance[]
  employees            Employee[]
  shifts               Shift[]
  policies             DeductionPolicy[]
}

model Department {
  id        String        @id @default(uuid()) @db.Uuid
  name      String
  code      String?    @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  employees Employee[]
  commissionPolicies CommissionPolicy[] @relation("CommissionPolicies")
  policies  DeductionPolicy[]
}

model Employee {
  id               String               @id @default(uuid()) @db.Uuid
  employeeID       String?           @unique
  userId           String? @db.Uuid              @unique
  employeeCode     String            @unique
  firstName        String
  lastName         String
  designation      String?
  mobileNumber     String?
  joiningDate      DateTime?
  reportingManagerId String? @db.Uuid
  designationId    String? @db.Uuid
  status           String            @default("active")
  workModeId       String            @default("OFFICE")
  workMode         WorkMode?         @relation(fields: [workModeId], references: [id])
  shiftTypeId      String            @default("MORNING")
  officeId         String? @db.Uuid
  departmentId     String? @db.Uuid
  storeId          String? @db.Uuid
  // Bank Details
  bankName         String?
  accountNumber    String?
  ifscCode         String?
  accountType      String?           @default("Savings")
  branchName       String?
  customPunchRadius Float?
  commissionPercentage Float?
  source           String            @default("HOPKID")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  attendances      Attendance[]
  department       Department?       @relation(fields: [departmentId], references: [id])
  office           Office?           @relation(fields: [officeId], references: [id])
  store            Store?            @relation(fields: [storeId], references: [id])
  user             User?             @relation(fields: [userId], references: [id])
  expenses         Expense[]
  leaveRequests    LeaveRequest[]
  leaveBalance     LeaveBalance?
  notifications    Notification[]
  shiftAssignments ShiftAssignment[]
  assignedTasks    Task[]            @relation("AssignedTasks")
  payslips         Payslip[]
  documents        Document[]
  attendanceCorrections AttendanceCorrection[]
  assets           Asset[]
  salaryStructure  SalaryStructure?
  designationRelation Designation?     @relation(fields: [designationId], references: [id])
  reportingManager Employee?         @relation("ReportingHierarchy", fields: [reportingManagerId], references: [id])
  subordinates     Employee[]        @relation("ReportingHierarchy")
  wallet           Wallet?
  commissionPolicies CommissionPolicy[] @relation("CommissionPolicies")
  commissionTransactions CommissionTransaction[] @relation("CommissionTransactions")
  commissionTargets CommissionTarget[] @relation("CommissionTargets")
  commissionSettlements CommissionSettlement[] @relation("CommissionSettlements")
  breaks           Break[]
  shiftRequests    ShiftRequest[]
  locationHistory  LocationHistory[]
  branch           Branch?           @relation(fields: [branchId], references: [id])
  branchId         String? @db.Uuid

  @@index([officeId])
  @@index([departmentId])
  @@index([storeId])
  @@index([status])
}

model Attendance {
  id                    String       @id @default(uuid()) @db.Uuid
  employeeId            String @db.Uuid
  officeId              String? @db.Uuid
  date                  String
  checkIn               DateTime?
  checkOut              DateTime?
  status                String    @default("ABSENT")
  notes                 String?
  latitude              Float?    @db.DoublePrecision
  longitude             Float?    @db.DoublePrecision
  isFingerprintCheckIn  Boolean   @default(false)
  isFingerprintCheckOut Boolean   @default(false)
  isOnBreak             Boolean   @default(false)
  breakStartTime        DateTime?
  totalBreakSeconds     Int       @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  employee              Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  office                Office?   @relation(fields: [officeId], references: [id])
  attendanceCorrections AttendanceCorrection[]
  breakRecords          BreakRecord[]

  @@index([date])
  @@index([employeeId])
  @@index([status])
  @@index([employeeId, date])
}

model Comment {
  id         String      @id @default(uuid()) @db.Uuid
  entityType String
  entityId   String
  content    String
  authorId   String @db.Uuid
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model LiveLocation {
  id         String      @id @default(uuid()) @db.Uuid
  employeeId String @db.Uuid      @unique
  name       String
  role       String
  lat        Float
  lng        Float
  status     String
  speed      String   @default("0 km/h")
  battery    String   @default("100%")
  updatedAt  DateTime @updatedAt
}

model LeaveRequest {
  id         String      @id @default(uuid()) @db.Uuid
  employeeId String @db.Uuid
  type       String
  fromDate   DateTime
  toDate     DateTime
  reason     String
  status     String   @default("PENDING")
  appliedOn  DateTime @default(now())
  reviewedBy String?
  reviewNote String?
  reviewedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt        DateTime @updatedAt
  leaveCategory    String   @default("PLANNED")
  deductionApplied Boolean  @default(false)
  employee         Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
  @@index([fromDate])
  @@index([employeeId, status])
}

model LeaveBalance {
  id           String      @id @default(uuid()) @db.Uuid
  employeeId   String @db.Uuid      @unique
  fiscalYear   String   @default("2026")
  casualTotal  Int      @default(12)
  casualUsed   Int      @default(0)
  sickTotal    Int      @default(10)
  sickUsed     Int      @default(0)
  earnedTotal  Int      @default(15)
  earnedUsed   Int      @default(0)
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Expense {
  id          String      @id @default(uuid()) @db.Uuid
  employeeId  String @db.Uuid
  category    String
  amount      Float
  description String
  date        DateTime
  status      String   @default("PENDING")
  submittedOn DateTime @default(now())
  reviewedBy  String?
  reviewNote  String?
  hasReceipt  Boolean  @default(false)
  receiptUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
  @@index([date])
  @@index([employeeId, status])
}

model Task {
  id           String      @id @default(uuid()) @db.Uuid
  title        String
  description  String
  assignedToId String @db.Uuid
  assignedById String @db.Uuid
  projectName  String
  dueDate      DateTime
  status       String   @default("TODO")
  priority     String   @default("MEDIUM")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  assignedBy   User     @relation("AssignedByTasks", fields: [assignedById], references: [id], onDelete: Cascade)
  assignedTo   Employee @relation("AssignedTasks", fields: [assignedToId], references: [id], onDelete: Cascade)
}

model Shift {
  id           String               @id @default(uuid()) @db.Uuid
  name         String
  startTime    String
  endTime      String
  workingDays  String[]
  graceMinutes Int               @default(15)
  breakMinutes Int               @default(60)
  color        String            @default("#3BA38B")
  officeId     String? @db.Uuid
  roleId       String? @db.Uuid
  departmentId String? @db.Uuid
  office       Office?           @relation(fields: [officeId], references: [id], onDelete: Cascade)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  assignments  ShiftAssignment[]
}

model ShiftAssignment {
  id            String       @id @default(uuid()) @db.Uuid
  employeeId    String @db.Uuid
  shiftId       String @db.Uuid
  workModeId    String    @default("OFFICE")
  workMode      WorkMode? @relation(fields: [workModeId], references: [id])
  shiftTypeId   String    @default("MORNING")
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift         Shift     @relation(fields: [shiftId], references: [id], onDelete: Cascade)
}

model Notification {
  id         String       @id @default(uuid()) @db.Uuid
  employeeId String? @db.Uuid
  userId     String? @db.Uuid
  title      String
  body       String
  category   String    @default("GENERAL")
  isRead     Boolean   @default(false)
  actionId   String?
  actionType String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model Holiday {
  id          String      @id @default(uuid()) @db.Uuid
  name        String
  date        DateTime
  isPublic    Boolean  @default(true)
  description String?
  type        String   @default("mandatory")
  recurring   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Document {
  id          String      @id @default(uuid()) @db.Uuid
  title       String
  type        String
  date        DateTime
  fileSize    String
  filePath    String?
  employeeId  String? @db.Uuid
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  employee    Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model AttendanceCorrection {
  id                String       @id @default(uuid()) @db.Uuid
  attendanceId      String @db.Uuid
  employeeId        String @db.Uuid
  correctionType    String
  requestedCheckIn  DateTime?
  requestedCheckOut DateTime?
  originalCheckIn   DateTime?
  originalCheckOut  DateTime?
  reason            String
  status            String    @default("PENDING")
  requestedBy       String
  reviewedBy        String?
  reviewedAt        DateTime?
  approvedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  attendance        Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  employee          Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Announcement {
  id          String      @id @default(uuid()) @db.Uuid
  title       String
  content     String
  category    String   @default("GENERAL")
  publishedBy String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PricingPlan {
  id           String      @id @default(uuid()) @db.Uuid
  name         String   @unique
  monthlyPrice Float
  yearlyPrice  Float
  seatsLabel   String   @default("")
  description  String   @default("")
  features     String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model RolePermission {
  id          String      @id @default(uuid()) @db.Uuid
  role        Role     @unique
  permissions Json
  updatedAt   DateTime @updatedAt
}

model UserPermission {
  id          String      @id @default(uuid()) @db.Uuid
  userId      String @db.Uuid      @unique
  permissions Json
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemSetting {
  id            String      @id @default(uuid()) @db.Uuid
  platformName  String   @default("Super HRM")
  supportEmail  String   @default("admin@hrm.com")
  currency      String   @default("INR")
  locale        String   @default("en")
  twoFactor     Boolean  @default(true)
  sessionLock   Boolean  @default(true)
  auditLogs     Boolean  @default(true)
  ipRestriction Boolean  @default(false)
  notifications Json?
  company       Json?
  attendance    Json?
  leave         Json?
  payroll       Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum Role {
  SUPER_ADMIN
  ADMIN
  HR
  PLATFORM_ADMIN
  EMPLOYEE
  STORE_MANAGER
  SALESMAN
  HELPER
}

model Payslip {
  id                String      @id @default(uuid()) @db.Uuid
  employeeId        String @db.Uuid
  month             Int
  year              Int
  baseSalary        Float
  allowance         Float
  deductions        Float
  netSalary         Float
  status            String   @default("Approved")
  employeeCode      String
  employeeName      String
  designation       String
  department        String
  officeName        String
  netInWords        String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  employee          Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month, year])
}

model FCMToken {
  id          String      @id @default(uuid()) @db.Uuid
  userId      String @db.Uuid
  token       String
  platform    String   @default("unknown")
  isActive    Boolean  @default(true)
  lastUsedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
}

model UserSession {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String @db.Uuid
  token      String   @unique
  deviceInfo String?
  ipAddress  String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String? @db.Uuid
  employeeId String? @db.Uuid
  branchId   String? @db.Uuid
  ipAddress  String?
  deviceInfo String?
  action     String
  timestamp  DateTime @default(now())
}

model Asset {
  id           String       @id @default(uuid()) @db.Uuid
  name         String
  code         String    @unique
  type         String
  status       String    @default("AVAILABLE")
  employeeId   String? @db.Uuid
  assignedDate DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  employee     Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
}

model Project {
  id          String      @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Designation {
  id        String        @id @default(uuid()) @db.Uuid
  name      String     @unique
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  employees Employee[]
  commissionPolicies CommissionPolicy[] @relation("CommissionPolicies")
}

model CustomRole {
  id        String      @id @default(uuid()) @db.Uuid
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Store {
  id          String       @id @default(uuid()) @db.Uuid
  name        String
  code        String?   @unique
  address     String?
  country     String    @default("India")
  pincode     String?
  maxPunchRadiusMeters Float? @default(50.0)
  latitude    Float?
  longitude   Float?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  employees   Employee[]
  commissionPolicies CommissionPolicy[] @relation("CommissionPolicies")
  commissionTransactions CommissionTransaction[] @relation("CommissionTransactions")
  commissionTargets CommissionTarget[] @relation("CommissionTargets")
}

model SalaryStructure {
  id               String      @id @default(uuid()) @db.Uuid
  employeeId       String @db.Uuid      @unique
  monthlySalary    Float    @default(0)
  grossSalary      Float    @default(0)
  basicSalary      Float    @default(0)
  hra              Float    @default(0)
  medicalAllowance Float    @default(0)
  travelAllowance  Float    @default(0)
  specialAllowance Float    @default(0)
  incentive        Float    @default(0)
  bonus            Float    @default(0)
  pfEnabled        Boolean  @default(false)
  employeePfRate   Float    @default(12.0)
  employerPfRate   Float    @default(12.0)
  esicEnabled      Boolean  @default(false)
  employeeEsicRate Float    @default(0.75)
  employerEsicRate Float    @default(3.25)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  employee         Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model BreakRecord {
  id           String        @id @default(uuid()) @db.Uuid
  attendanceId String @db.Uuid
  startTime    DateTime
  endTime      DateTime?
  duration     Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  attendance   Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
}

model Wallet {
  id                String      @id @default(uuid()) @db.Uuid
  employeeId        String @db.Uuid      @unique
  availableBalance  Float    @default(0)
  advanceLimit      Float    @default(0)
  pendingClaims     Float    @default(0)
  cardNumber        String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  employee          Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  transactions      WalletTransaction[]
  advances          SalaryAdvance[]

  @@index([employeeId])
}

model WalletTransaction {
  id          String      @id @default(uuid()) @db.Uuid
  walletId    String @db.Uuid
  title       String
  category    String
  amount      Float
  date        DateTime
  status      String   @default("PENDING")
  isCredit    Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  wallet      Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([date])
  @@index([status])
}

model SalaryAdvance {
  id          String      @id @default(uuid()) @db.Uuid
  walletId    String @db.Uuid
  amount      Float
  months      Int
  reason      String
  status      String   @default("PENDING")
  requestedOn DateTime @default(now())
  reviewedBy  String?
  reviewNote  String?
  reviewedAt  DateTime?
  approvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  wallet      Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([status])
}

// Commission Management Module

model CommissionPolicy {
  id                String      @id @default(uuid()) @db.Uuid
  name              String
  description       String?
  commissionType    String   @default("PERCENTAGE") // PERCENTAGE, FIXED, NONE
  commissionValue   Float
  priority          Int      @default(0) // 0=Head Office, 1=Store, 2=Employee
  effectiveFrom     DateTime @default(now())
  effectiveTo       DateTime?
  isActive          Boolean  @default(true)
  
  // Scope fields
  storeId           String? @db.Uuid
  employeeId        String? @db.Uuid
  departmentId      String? @db.Uuid
  designationId     String? @db.Uuid
  roleId            String?
  
  // Product/Category/Brand specific
  productId         String? @db.Uuid
  categoryId        String? @db.Uuid
  brandId           String? @db.Uuid
  
  // Target & Bonus
  targetAmount      Float?
  targetBonus       Float?
  monthlyBonus      Float?
  quarterlyBonus    Float?
  yearlyBonus       Float?
  maxCommission     Float?
  minTarget         Float?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  store             Store?   @relation("CommissionPolicies", fields: [storeId], references: [id])
  employee          Employee? @relation("CommissionPolicies", fields: [employeeId], references: [id])
  department        Department? @relation("CommissionPolicies", fields: [departmentId], references: [id])
  designation       Designation? @relation("CommissionPolicies", fields: [designationId], references: [id])
  transactions      CommissionTransaction[]
  targets           CommissionTarget[]
  
  @@index([storeId])
  @@index([employeeId])
  @@index([isActive])
  @@index([effectiveFrom])
}

model CommissionTransaction {
  id                String      @id @default(uuid()) @db.Uuid
  billId            String?
  invoiceNumber     String?
  employeeId        String @db.Uuid
  storeId           String? @db.Uuid
  saleAmount        Float
  commissionType    String   // PERCENTAGE, FIXED
  commissionPercent Float?
  commissionAmount  Float
  status            String   @default("PENDING") // PENDING, APPROVED, REJECTED, PAID
  approvedBy        String? @db.Uuid
  approvedAt        DateTime?
  payrollId         String? @db.Uuid
  paidAt            DateTime?
  notes             String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  employee          Employee @relation("CommissionTransactions", fields: [employeeId], references: [id])
  store             Store?   @relation("CommissionTransactions", fields: [storeId], references: [id])
  policy            CommissionPolicy? @relation(fields: [policyId], references: [id])
  policyId          String? @db.Uuid
  history           CommissionHistory[]
  adjustments       CommissionAdjustment[]
  
  @@index([employeeId])
  @@index([storeId])
  @@index([status])
  @@index([createdAt])
  @@index([payrollId])
}

model CommissionHistory {
  id                String      @id @default(uuid()) @db.Uuid
  transactionId     String @db.Uuid
  employeeId        String @db.Uuid
  action            String   // CREATED, APPROVED, REJECTED, PAID, ADJUSTED
  previousStatus    String?
  newStatus         String?
  previousAmount    Float?
  newAmount         Float?
  reason            String?
  performedBy       String? @db.Uuid
  performedAt       DateTime @default(now())
  
  // Relations
  transaction       CommissionTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  
  @@index([transactionId])
  @@index([employeeId])
  @@index([action])
  @@index([performedAt])
}

model CommissionTarget {
  id                String      @id @default(uuid()) @db.Uuid
  policyId          String @db.Uuid
  employeeId        String? @db.Uuid
  storeId           String? @db.Uuid
  targetType        String   // MONTHLY, QUARTERLY, YEARLY
  targetAmount      Float
  achievedAmount    Float    @default(0)
  progressPercent   Float    @default(0)
  startDate         DateTime
  endDate           DateTime
  status            String   @default("ACTIVE") // ACTIVE, ACHIEVED, MISSED, CANCELLED
  bonusAmount       Float?
  bonusPaid         Boolean  @default(false)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  policy            CommissionPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  employee          Employee? @relation("CommissionTargets", fields: [employeeId], references: [id])
  store             Store?   @relation("CommissionTargets", fields: [storeId], references: [id])
  
  @@index([policyId])
  @@index([employeeId])
  @@index([storeId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

model CommissionSettlement {
  id                String      @id @default(uuid()) @db.Uuid
  employeeId        String @db.Uuid
  settlementDate    DateTime
  totalCommission   Float
  totalBonus        Float
  totalDeduction    Float    @default(0)
  netAmount         Float
  status            String   @default("PENDING") // PENDING, PROCESSED, PAID
  payrollId         String? @db.Uuid
  processedBy       String? @db.Uuid
  processedAt       DateTime?
  notes             String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  employee          Employee @relation("CommissionSettlements", fields: [employeeId], references: [id])
  
  @@index([employeeId])
  @@index([settlementDate])
  @@index([status])
  @@index([payrollId])
}

model CommissionAdjustment {
  id                String      @id @default(uuid()) @db.Uuid
  transactionId     String @db.Uuid
  employeeId        String @db.Uuid
  adjustmentType    String   // INCREASE, DECREASE
  adjustmentAmount  Float
  reason            String
  approvedBy        String? @db.Uuid
  approvedAt        DateTime?
  status            String   @default("PENDING") // PENDING, APPROVED, REJECTED
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  transaction       CommissionTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  
  @@index([transactionId])
  @@index([employeeId])
  @@index([status])
}

model WorkMode {
  id               String            @id // e.g. "OFFICE", "REMOTE", "HYBRID"
  name             String            // Display name e.g. "Office", "Remote", "Hybrid"
  employees        Employee[]
  shiftAssignments ShiftAssignment[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}


model DeductionPolicy {
  id                String      @id @default(uuid()) @db.Uuid
  name              String
  type              String   // LATE_MARK, LEAVE, ABSENT
  deductionType     String   // FIXED_AMOUNT, PERCENTAGE, PER_DAY
  deductionValue    Float
  maxDeduction      Float?   // Maximum deduction amount per month
  applicableDays    String[] // Days this policy applies to (e.g., ["Monday", "Tuesday"])
  departmentId      String? @db.Uuid
  officeId          String? @db.Uuid
  isActive          Boolean  @default(true)
  effectiveFrom     DateTime @default(now())
  effectiveTo       DateTime?
  description       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  createdBy         String?
  
  department        Department? @relation(fields: [departmentId], references: [id])
  office            Office? @relation(fields: [officeId], references: [id])

  @@index([type])
  @@index([departmentId])
  @@index([officeId])
  @@index([isActive])
}

model AttendanceGenerationPolicy {
  id                                String      @id @default(uuid()) @db.Uuid
  isEnabled                         Boolean  @default(false)
  generationMode                    String   @default("MONTHLY") // DAILY, WEEKLY, MONTHLY
  autoGenerateCurrentMonth          Boolean  @default(true)
  autoGenerateFutureMonths          Boolean  @default(false)
  numberOfFutureMonths              Int      @default(1)
  payrollCutoffDate                 Int      @default(25) // Day of month (1-31)
  attendanceFreezeDate             Int      @default(28) // Day of month (1-31)
  autoGenerateWeeklyOffs            Boolean  @default(true)
  autoApplyHolidays                 Boolean  @default(true)
  autoApplyShiftCalendar            Boolean  @default(true)
  autoMarkAbsentAfterWorkingHours   Boolean  @default(false)
  autoApplyHalfDayRules            Boolean  @default(true)
  autoApplyLateMarkRules           Boolean  @default(true)
  autoApplyEarlyExitRules           Boolean  @default(true)
  departmentId                      String? @db.Uuid
  officeId                          String? @db.Uuid
  effectiveFrom                     DateTime @default(now())
  effectiveTo                       DateTime?
  description                       String?
  createdAt                         DateTime @default(now())
  updatedAt                         DateTime @updatedAt
  createdBy                         String?

  @@index([isEnabled])
  @@index([departmentId])
  @@index([officeId])
}

model Device {
  id        String      @id @default(uuid()) @db.Uuid
  userId    String @db.Uuid
  fcmToken  String   @unique
  platform  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("devices")
}

model Break {
  id         String       @id @default(uuid()) @db.Uuid
  employeeId String @db.Uuid
  type       String    // LUNCH, TEA, PERSONAL, MEETING
  startAt    DateTime
  endAt      DateTime?
  date       String    // YYYY-MM-DD
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model ShiftRequest {
  id             String       @id @default(uuid()) @db.Uuid
  employeeId     String @db.Uuid
  currentShift   String
  requestedShift String
  reason         String
  status         String    @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt      DateTime  @default(now())
  decidedAt      DateTime?
  decidedBy      String? @db.Uuid
  employee       Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Branch {
  id           String        @id @default(uuid()) @db.Uuid
  name         String
  latitude     Float
  longitude    Float
  radiusMeters Float
  employees    Employee[]
}

model LocationHistory {
  id         String      @id @default(uuid()) @db.Uuid
  employeeId String @db.Uuid
  latitude   Float
  longitude  Float
  isOutside  Boolean  @default(false)
  at         DateTime
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ─── HR Task Management ────────────────────────────────────────────────────────

model HrTask {
  id          String        @id @default(uuid()) @db.Uuid
  title       String
  description String?       @db.Text
  assignedTo  String        // Employee.employeeID (HopKid GUID or local-* string)
  assignedBy  String        @db.Uuid // User.id of HR creator
  priority    HrPriority    @default(MEDIUM)
  dueDate     DateTime?
  status      HrTaskStatus  @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  updates     HrTaskUpdate[]

  @@index([assignedTo])
  @@index([status])
  @@index([dueDate])
}

model HrTaskUpdate {
  id        String        @id @default(uuid()) @db.Uuid
  taskId    String        @db.Uuid
  task      HrTask        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  byUserId  String @db.Uuid           // User.id of actor
  oldStatus HrTaskStatus?
  newStatus HrTaskStatus
  comment   String?       @db.Text
  at        DateTime      @default(now())

  @@index([taskId])
}

enum HrPriority {
  LOW
  MEDIUM
  HIGH
}

enum HrTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
