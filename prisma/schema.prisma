// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  HR
  PLATFORM_ADMIN
  EMPLOYEE
}

model User {
  id             Int             @id @default(autoincrement())
  email          String          @unique
  password       String
  role           Role            @default(EMPLOYEE)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  profile        Profile?
  employee       Employee?
  comments       Comment[]
  assignedTasks  Task[]          @relation("AssignedByTasks")
  userPermission UserPermission?
  fcmTokens      String[]        @default([])
}

model Profile {
  id                Int      @id @default(autoincrement())
  userId            Int      @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email             String
  fullName          String
  phone             String   @default("")
  avatarUrl         String?  @default("/favicon.svg")
  timezone          String   @default("Asia/Kolkata")
  timezoneLabel     String   @default("(GMT+5:30) Mumbai, New Delhi")
  bio               String   @default("")
  twoFactorEnabled  Boolean  @default(false)
  twoFactorStatus   String   @default("disabled")
  lastLoginAt       DateTime @default(now())
  lastLoginLocation String   @default("Unknown")
  clearanceLevel    Int      @default(1)
  clearanceLabel    String   @default("Level 1 (General)")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Office {
  id                   Int          @id @default(autoincrement())
  name                 String
  code                 String?      @unique
  address              String
  latitude             Float
  longitude            Float
  idealRadiusMeters    Float        @default(25.0)
  maxPunchRadiusMeters Float        @default(50.0)
  isActive             Boolean      @default(true)
  subscriptionPlan     String       @default("Basic")
  billingCycle         String       @default("monthly")
  invoiceStatus        String       @default("Paid")
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  employees            Employee[]
  attendances          Attendance[]
}

model Department {
  id        Int        @id @default(autoincrement())
  name      String
  code      String?    @unique
  employees Employee[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Employee {
  id               Int                @id @default(autoincrement())
  userId           Int?               @unique
  user             User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  employeeCode     String             @unique
  firstName        String
  lastName         String
  designation      String?
  status           String             @default("active")
  officeId         Int?
  office           Office?            @relation(fields: [officeId], references: [id], onDelete: SetNull)
  departmentId     Int?
  department       Department?        @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  attendances      Attendance[]
  leaveRequests    LeaveRequest[]
  expenses         Expense[]
  assignedTasks    Task[]             @relation("AssignedTasks")
  shiftAssignments ShiftAssignment[]
  notifications    Notification[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model Attendance {
  id                    Int       @id @default(autoincrement())
  employeeId            Int
  employee              Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  officeId              Int?
  office                Office?   @relation(fields: [officeId], references: [id], onDelete: SetNull)
  date                  String // Format YYYY-MM-DD
  checkIn               DateTime?
  checkOut              DateTime?
  status                String    @default("ABSENT") // PRESENT, ABSENT, LATE, HALF_DAY, LEAVE, WEEKEND, HOLIDAY
  notes                 String?
  latitude              Float?
  longitude             Float?
  isFingerprintCheckIn  Boolean   @default(false)
  isFingerprintCheckOut Boolean   @default(false)
  isOnBreak             Boolean   @default(false)
  breakStartTime        DateTime?
  totalBreakSeconds     Int       @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Comment {
  id         Int      @id @default(autoincrement())
  entityType String // OFFICE, EMPLOYEE, etc.
  entityId   String // Reference ID
  content    String
  authorId   Int
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model LiveLocation {
  id         Int      @id @default(autoincrement())
  employeeId Int      @unique
  name       String
  role       String
  lat        Float
  lng        Float
  status     String
  speed      String   @default("0 km/h")
  battery    String   @default("100%")
  updatedAt  DateTime @updatedAt
}

model LeaveRequest {
  id         Int      @id @default(autoincrement())
  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type       String // CASUAL, SICK, EARNED, MATERNITY, PATERNITY, UNPAID
  fromDate   DateTime
  toDate     DateTime
  reason     String
  status     String   @default("PENDING") // PENDING, APPROVED, REJECTED, CANCELLED
  appliedOn  DateTime @default(now())
  reviewedBy String?
  reviewNote String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Expense {
  id          Int      @id @default(autoincrement())
  employeeId  Int
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  category    String // TRAVEL, FOOD, ACCOMMODATION, STATIONERY, MEDICAL, OTHER
  amount      Float
  description String
  date        DateTime
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED, REIMBURSED
  submittedOn DateTime @default(now())
  reviewedBy  String?
  reviewNote  String?
  hasReceipt  Boolean  @default(false)
  receiptUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id           Int      @id @default(autoincrement())
  title        String
  description  String
  assignedToId Int
  assignedTo   Employee @relation("AssignedTasks", fields: [assignedToId], references: [id], onDelete: Cascade)
  assignedById Int
  assignedBy   User     @relation("AssignedByTasks", fields: [assignedById], references: [id], onDelete: Cascade)
  projectName  String
  dueDate      DateTime
  status       String   @default("TODO") // TODO, IN_PROGRESS, COMPLETED, OVERDUE
  priority     String   @default("MEDIUM") // LOW, MEDIUM, HIGH
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Shift {
  id           Int               @id @default(autoincrement())
  name         String
  startTime    String // "09:00"
  endTime      String // "18:00"
  workingDays  String[] // ["Mon", "Tue", "Wed", "Thu", "Fri"]
  graceMinutes Int               @default(15)
  breakMinutes Int               @default(60)
  color        String            @default("#3BA38B")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  assignments  ShiftAssignment[]
}

model ShiftAssignment {
  id            Int       @id @default(autoincrement())
  employeeId    Int
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shiftId       Int
  shift         Shift     @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Notification {
  id         Int      @id @default(autoincrement())
  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  title      String
  body       String
  category   String   @default("GENERAL") // ATTENDANCE, LEAVE, TASK, EXPENSE, ANNOUNCEMENT, PAYROLL, GENERAL
  isRead     Boolean  @default(false)
  actionId   String?
  actionType String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Announcement {
  id          Int      @id @default(autoincrement())
  title       String
  content     String
  category    String   @default("GENERAL")
  publishedBy String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PricingPlan {
  id           Int      @id @default(autoincrement())
  name         String   @unique // "Basic", "Pro", "Enterprise"
  monthlyPrice Float
  yearlyPrice  Float
  seatsLabel   String   @default("")
  description  String   @default("")
  features     String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model RolePermission {
  id          Int      @id @default(autoincrement())
  role        Role     @unique
  permissions Json
  updatedAt   DateTime @updatedAt
}

model UserPermission {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissions Json
  updatedAt   DateTime @updatedAt
}
